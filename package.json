{
  "name": "anotherminor-github-io",
  "private": true,
  "version": "0.1.0",
  "description": "Hugo journal blog with Pagefind for GitHub Pages",
  "scripts": {
    "search:index": "npx --no-install pagefind --site public --glob \"posts/**/*.html\"",
    "validate:content": "ruby scripts/validate-content.rb",
    "generate-tags": "node scripts/generate-tag-pages.js",
    "migrate-tags": "node scripts/migrate-tags.js",
    "migrate-tags:apply": "node scripts/migrate-tags.js --apply",
    "prebuild": "npm run generate-tags",
    "build": "hugo --gc --minify --cleanDestinationDir --baseURL \"${BASE_URL:-http://localhost:1313/}\" && npm run search:index",
    "build:pages": "hugo --gc --minify --cleanDestinationDir --baseURL \"${BASE_URL:-http://localhost:1313/}\" && npx --no-install pagefind --site public --glob \"posts/**/*.html\""
  },
  "devDependencies": {
    "pagefind": "1.4.0"
  }
}
